<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dice Roller</title>

<style>
body {
    font-family: Arial, sans-serif;
    text-align: center;
    background: #f4f4f4;
    padding: 40px;
}

.container {
    background: white;
    padding: 20px;
    border-radius: 12px;
    max-width: 700px;
    margin: auto;
}

#dice {
    font-size: 60px;
    margin: 20px 0;
}

#total {
    font-size: 28px;
    font-weight: bold;
    margin-top: 15px;
}

button {
    padding: 10px 20px;
    font-size: 18px;
    cursor: pointer;
}

select {
    padding: 8px;
    font-size: 16px;
}
</style>
</head>
<body>

<div class="container">

<h1>🎲 Dice Roller</h1>

<label>Number of Dice:</label>

<select id="diceCount">
    <option value="1">1 Die</option>
    <option value="2">2 Dice</option>
    <option value="3">3 Dice</option>
    <option value="4">4 Dice</option>
    <option value="5">5 Dice</option>
    <option value="6">6 Dice</option>
</select>

<br><br>

<button onclick="rollDice()">Roll</button>

<div id="dice"></div>
<div id="rolls"></div>
<div id="total"></div>

</div>

<script>

const faces = ["","⚀","⚁","⚂","⚃","⚄","⚅"];

function rollDice() {

    const count =
        parseInt(document.getElementById("diceCount").value);

    let total = 0;
    let rolls = [];
    let display = "";

    for(let i = 0; i < count; i++) {

        const roll =
            Math.floor(Math.random() * 6) + 1;

        total += roll;
        rolls.push(roll);
        display += faces[roll] + " ";
    }

    document.getElementById("dice").innerHTML = display;
    document.getElementById("rolls").innerHTML =
        "Rolls: " + rolls.join(", ");
    document.getElementById("total").innerHTML =
        "Total: " + total;
}

</script>

</body>
</html>
